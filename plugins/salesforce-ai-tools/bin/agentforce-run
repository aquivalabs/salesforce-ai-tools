#!/usr/bin/env bash
set -euo pipefail

# Resolve the plugin root from this script's own location. CLAUDE_PLUGIN_ROOT
# is not reliably present in the shell Claude runs commands in, so we never
# depend on it — bin/ always lives one level below the plugin root.
PLUGIN_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

node "${PLUGIN_ROOT}/skills/agentforce/run.mjs" "$@"
