{
  "sites": [
    {
      "domain": "help.salesforce.com",
      "cookies": [
        { "name": "CookieConsentPolicy", "value": "0:1", "domain": "help.salesforce.com", "path": "/" },
        { "name": "LSKey-c$CookieConsentPolicy", "value": "0:1", "domain": "help.salesforce.com", "path": "/" },
        { "name": "OptanonAlertBoxClosed", "value": "2025-01-01T00:00:00.000Z", "domain": ".salesforce.com", "path": "/" },
        { "name": "OptanonConsent", "value": "isGpcEnabled=0&groups=1:1,3:1,4:1&isAnonUser=1", "domain": ".salesforce.com", "path": "/" },
        { "name": "sfdcConsent", "value": "1%2C3%2C4", "domain": ".salesforce.com", "path": "/" }
      ],
      "syntheticShadow": true,
      "content": {
        "selector": ".slds-text-longform",
        "removeSelectors": [".slds-max-small-hide", "c-hc-article-feedback"],
        "waitFor": ".slds-text-longform"
      }
    },
    {
      "domain": "developer.salesforce.com",
      "pathPattern": "/references/",
      "cookies": [
        { "name": "CookieConsentPolicy", "value": "0:1", "domain": "developer.salesforce.com", "path": "/" },
        { "name": "LSKey-c$CookieConsentPolicy", "value": "0:1", "domain": "developer.salesforce.com", "path": "/" },
        { "name": "OptanonAlertBoxClosed", "value": "2025-01-01T00:00:00.000Z", "domain": ".salesforce.com", "path": "/" },
        { "name": "OptanonConsent", "value": "isGpcEnabled=0&groups=1:1,3:1,4:1&isAnonUser=1", "domain": ".salesforce.com", "path": "/" },
        { "name": "sfdcConsent", "value": "1%2C3%2C4", "domain": ".salesforce.com", "path": "/" }
      ],
      "content": {
        "shadowPath": ["doc-amf-reference", "doc-amf-topic", "api-summary"],
        "selector": "div",
        "removeSelectors": ["api-url", "style"],
        "waitFor": ".marked-description"
      }
    },
    {
      "domain": "developer.salesforce.com",
      "pathPattern": "^/docs/(ai|einstein)/",
